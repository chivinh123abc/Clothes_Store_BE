BUILD_MODE=dev

PORT=3000
HOST=0.0.0.0

CLIENT_URL=http://localhost:5173

# DATABASE (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=clothes_store_db

# JWT
ACCESS_TOKEN_SECRET_SIGNATURE=
ACCESS_TOKEN_LIFE=1h
REFRESH_TOKEN_SECRET_SIGNATURE=
REFRESH_TOKEN_LIFE=2h

# MAIL (Gmail SMTP — use an App Password, not your real password)
# Generate at: Google Account → Security → 2-Step Verification → App Passwords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=

# CLOUDINARY (Image hosting — free tier at cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# MOMO PAYMENTS (Sandbox — register at developers.momo.vn)
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create

# CLOUDINARY AI (Optional — image try-on feature, register at replicate.com)
REPLICATE_API_TOKEN=

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379